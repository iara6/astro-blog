---
const str = "Bob"
const num = 1
const obj = {
  name: str,
  number: num,
  favorites: ["astro", "css", "js"]
}
/* const isVisible = true; */
const isVisible = false;

const res = await fetch("https://jsonplaceholder.typicode.com/posts?_limit=5");
const data = await res.json();

const { title } = Astro.props;
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<meta name="generator" content={Astro.generator} />
		<title>{title}</title>
	</head>
	<body>
    <h1>{obj.favorites[1].toUpperCase()}</h1>
    {
      isVisible &&
      <h2>{obj.favorites[2].toUpperCase()}</h2> /* hidden */
    }
    {
      isVisible
      ? <h2>{obj.favorites[2].toUpperCase()}</h2>
      : <h2>{obj.favorites[0].toUpperCase()}</h2> /*astro*/
    } 
    <h2>{obj.favorites[isVisible ? [2] : [0]].toUpperCase()}</h2> <!-- same as above -->
		<slot />

    <ul>
      {
        obj.favorites.map(item => (
          <li>{item}</li>
        ))
      }
    </ul>

    <ul>
      {
        data.map(post => (
          <li>{post.title}</li>
        ))
      }
    </ul>
	</body>
</html>

<style>
	html,
	body {
		margin: 0;
		width: 100%;
		height: 100%;
	}
</style>

